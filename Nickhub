local function anyEsp()
    return State.Battery or State.BatteryPack or State.Fuel
        or State.Bandage or State.Medkit or State.Crates
end

local function limpiarEsp()
    for _,i in ipairs(Workspace:GetDescendants()) do
        if i.Name=="EspEfecto" or i.Name=="EspTexto" then i:Destroy() end
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if anyEsp() then
            local dropped=Workspace:FindFirstChild("DroppedItems")
            if dropped then
                for _,item in ipairs(dropped:GetChildren()) do
                    local n=item.Name:upper()
                    if not n:find("SCRAP") then
                        if n=="BATTERY" and State.Battery then
                            aplicarEspItem(item,"Battery",Color3.fromRGB(50,230,50))
                        elseif n:find("BATTERY") and n~="BATTERY" and State.BatteryPack then
                            aplicarEspItem(item,"Battery Pack",Color3.fromRGB(0,200,100))
                        elseif n:find("FUEL") and State.Fuel then
                            aplicarEspItem(item,"Fuel",Color3.fromRGB(255,80,80))
                        elseif n:find("BANDAGE") and State.Bandage then
                            aplicarEspItem(item,"Bandage",Color3.fromRGB(255,230,80))
                        elseif n:find("MEDKIT") and State.Medkit then
                            aplicarEspItem(item,"Medkit",Color3.fromRGB(80,200,255))
                        else
                            removerEsp(item)
                        end
                    end
                end
            end
            if State.Crates then
                local crates=Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Crates")
                if crates then
                    for _,caja in ipairs(crates:GetChildren()) do
                        if caja:IsA("Model") or caja:IsA("BasePart") then
                            local hb=caja:FindFirstChild("Hitbox") or caja
                            local pr=hb:FindFirstChildOfClass("ProximityPrompt")
                                    or caja:FindFirstChildOfClass("ProximityPrompt")
                            if not pr or not pr.Enabled
                            or (pr.ActionText and pr.ActionText:upper():find("VACIO"))
                            or (pr.ObjectText and pr.ObjectText:upper():find("VACIO")) then
                                removerEsp(caja)
                            else
                                aplicarEspCrate(caja, Color3.fromRGB(255,140,0))
                            end
                        end
                    end
                end
            end
        else
            limpiarEsp()
        end
    end
end)

local noclipWasOn = false

RunService.Stepped:Connect(function()
    local char=LocalPlayer.Character
    if not char then return end
    if State.Noclip then
        noclipWasOn = true
        for _,v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    elseif noclipWasOn then
        noclipWasOn = false
        for _,v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") and not v.CanCollide then
                v.CanCollide = true
            end
        end
    end
end)

