task.spawn(function()
    while true do
        task.wait(COOLDOWN)
        if State.Aura then
            local character=LocalPlayer.Character
            local rootPart=character and character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local objetivos={}
                local carpeta=Workspace:FindFirstChild("Characters")
                if carpeta then
                    for _,mob in ipairs(carpeta:GetChildren()) do
                        if mob~=character and mob:FindFirstChild("HumanoidRootPart") then
                            local hum=mob:FindFirstChildOfClass("Humanoid")
                            if (hum and hum.Health>0) or not hum then
                                local dist=(rootPart.Position-mob.HumanoidRootPart.Position).Magnitude
                                if dist<=MAX_DISTANCIA then table.insert(objetivos,mob) end
                            end
                        end
                    end
                end
                if #objetivos>0 then
                    local swingRE,hitRE
                    for _,obj in ipairs(character:GetChildren()) do
                        if obj:IsA("Tool") or (obj:IsA("Model") and obj:FindFirstChild("HitTargets")) then
                            if obj:FindFirstChild("Swing") then swingRE=obj.Swing end
                            if obj:FindFirstChild("HitTargets") then hitRE=obj.HitTargets end
                        end
                    end
                    if hitRE and hitRE:IsA("RemoteEvent") then
                        if swingRE and swingRE:IsA("RemoteEvent") then
                            task.spawn(function() swingRE:FireServer() end)
                        end
                        for i=1,MULTI_HIT do hitRE:FireServer(objetivos) end
                    end
                end
            end
        end
    end
end)

local function removerEsp(m)
    local h=m:FindFirstChild("EspEfecto")
    local b=m:FindFirstChild("EspTexto")
    if h then h:Destroy() end
    if b then b:Destroy() end
end

local function aplicarEspItem(m, nombre, col)
    local hl=m:FindFirstChild("EspEfecto")
    if not hl then
        hl=Instance.new("Highlight")
        hl.Name="EspEfecto"
        hl.FillColor=col
        hl.FillTransparency=0.65
        hl.OutlineColor=col
        hl.OutlineTransparency=0.2
        hl.Adornee=m
        hl.Parent=m
    else
        hl.FillColor=col
        hl.OutlineColor=col
    end

    local bb=m:FindFirstChild("EspTexto")
    if not bb then
        bb=Instance.new("BillboardGui")
        bb.Name="EspTexto"
        bb.Size=UDim2.new(0,100,0,20)
        bb.AlwaysOnTop=true
        bb.Adornee=m
        bb.ExtentsOffset=Vector3.new(0,2.5,0)
        bb.Parent=m

        local lbl=Instance.new("TextLabel")
        lbl.Name="EspLabel"
        lbl.Size=UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency=1
        lbl.TextColor3=col
        lbl.TextStrokeColor3=Color3.new(0,0,0)
        lbl.TextStrokeTransparency=0
        lbl.Font=Enum.Font.GothamBold
        lbl.TextSize=12
        lbl.Text=nombre
        lbl.TextXAlignment=Enum.TextXAlignment.Center
        lbl.Parent=bb
    else
        local lbl=bb:FindFirstChild("EspLabel")
        if lbl then lbl.TextColor3=col end
    end
end

