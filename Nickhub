local function openPanel()
    Panel.Visible = true
    local targetH = PanelInner.AbsoluteSize.Y
    if targetH < 10 then targetH = 100 end
    Panel.Size = UDim2.new(0,180,0,0)
    TweenService:Create(Panel,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{
        Size=UDim2.new(0,180,0,targetH)
    }):Play()
end

local function closePanel()
    TweenService:Create(Panel,TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{
        Size=UDim2.new(0,180,0,0)
    }):Play()
    task.delay(0.13, function() Panel.Visible = false end)
end

