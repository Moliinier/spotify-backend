-- SISTEMA VISUAL ESP MEJORADO
local function aplicarEspAObjeto(modelo, texto, color)
    local highlight = modelo:FindFirstChild("EspEfecto")
    local billboard = modelo:FindFirstChild("EspTexto")
    
    if highlight and billboard then
        highlight.FillColor = color
        local label = billboard:FindFirstChildOfClass("TextLabel")
        if label and label.Text ~= texto then
            label.Text = texto
            label.TextColor3 = color
        end
        return
    end

    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "EspEfecto"
        highlight.FillColor = color
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0.3
        highlight.Adornee = modelo
        highlight.Parent = modelo

        billboard = Instance.new("BillboardGui")
        billboard.Name = "EspTexto"
        billboard.Size = UDim2.new(0, 150, 0, 35)
        billboard.AlwaysOnTop = true
        billboard.Adornee = modelo
        billboard.ExtentsOffset = Vector3.new(0, 2.5, 0)

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color
        label.Font = Enum.Font.GothamBlack
        label.TextSize = 14
        label.Text = texto
        
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(15, 15, 15)
        stroke.Thickness = 1.5
        stroke.Parent = label

        label.Parent = billboard
        billboard.Parent = modelo
    end
end

local function limpiarEsp()
    for _, item in ipairs(Workspace:GetDescendants()) do
        if item.Name == "EspEfecto" or item.Name == "EspTexto" then
            item:Destroy()
        end
    end
end

-- BUCLE 1: VELOCIDAD DINÁMICA
task.spawn(function()
    while true do
        task.wait(0.1)
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local velocidadObjetivo = NoclipActivo and VELOCIDAD_NOCLIP or VELOCIDAD_NORMAL
            if humanoid.WalkSpeed ~= velocidadObjetivo then
                humanoid.WalkSpeed = velocidadObjetivo
            end
        end
    end
end)

-- BUCLE 2: KILL AURA
task.spawn(function()
    while true do
        task.wait(COOLDOWN)
        if AuraActiva then
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local objetivos = {}
                local carpetaCaracteres = Workspace:FindFirstChild("Characters")
                if carpetaCaracteres then
                    for _, mob in ipairs(carpetaCaracteres:GetChildren()) do
                        if mob ~= character and mob:FindFirstChild("HumanoidRootPart") then
                            local humanoid = mob:FindFirstChildOfClass("Humanoid")
                            if (humanoid and humanoid.Health > 0) or (not humanoid) then
                                local distancia = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
                                if distancia <= MAX_DISTANCIA then
                                    table.insert(objetivos, mob)
                                end
                            end
                        end
                    end
                end
                
                if #objetivos > 0 then
                    local swingRemote, hitTargetsRemote
                    for _, obj in ipairs(character:GetChildren()) do
                        if obj:IsA("Tool") or (obj:IsA("Model") and obj:FindFirstChild("HitTargets")) then
                            if obj:FindFirstChild("Swing") then swingRemote = obj.Swing end
                            if obj:FindFirstChild("HitTargets") then hitTargetsRemote = obj.HitTargets end
                        end
                    end
                    
                    if hitTargetsRemote and hitTargetsRemote:IsA("RemoteEvent") then
                        if swingRemote and swingRemote:IsA("RemoteEvent") then
                            task.spawn(function() swingRemote:FireServer() end)
                        end
                        for i = 1, MULTI_HIT do
                            hitTargetsRemote:FireServer(objetivos)
                        end
                    end
                end
            end
        end
    end
end)

-- BUCLE 3: ESP CON DETECCIÓN INTELIGENTE
task.spawn(function()
    while true do
        task.wait(0.5)
        if EspActivo then
            -- 1. Objetos tirados
            local carpetaDropped = Workspace:FindFirstChild("DroppedItems")
            if carpetaDropped then
                for _, item in ipairs(carpetaDropped:GetChildren()) do
                    local n = item.Name:upper()
                    if n ~= "SCRAP" and not n:find("SCRAP") then
                        if n == "BATTERY" then aplicarEspAObjeto(item, "🔋 BATTERY", Color3.fromRGB(50, 255, 50))
                        elseif n == "BATTERY PACK" or n:find("BATTERY") then aplicarEspAObjeto(item, "🔋 BATTERY (x3)", Color3.fromRGB(0, 200, 100))
                        elseif n == "FUEL" or n:find("FUEL") then aplicarEspAObjeto(item, "⛽ FUEL", Color3.fromRGB(255, 100, 50))
                        elseif n:find("BANDAGE") or n:find("VENDA") then aplicarEspAObjeto(item, "🩹 VENDA", Color3.fromRGB(255, 150, 150))
                        elseif n:find("MEDKIT") or n:find("BOTIQUIN") then aplicarEspAObjeto(item, "🏥 BOTIQUÍN", Color3.fromRGB(255, 20, 20))
                        end
                    end
                end
            end

            -- 2. Mapa: Cajas y Barriles (Lógica de Prompt mejorada)
            local mapFolder = Workspace:FindFirstChild("Map")
            if mapFolder then
                for _, obj in ipairs(mapFolder:GetDescendants()) do
                    if (obj:IsA("Model") or obj:IsA("BasePart")) then
                        local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or (obj:FindFirstChild("Hitbox") and obj.Hitbox:FindFirstChildOfClass("ProximityPrompt"))
                        
                        if prompt then
                            local accion = prompt.ActionText:upper()
                            -- Filtramos por prompts de acción real, ignorando basura
                            if accion:find("ABRIR") or accion:find("OPEN") then
                                aplicarEspAObjeto(obj, "CAJA", Color3.fromRGB(255, 170, 0))
                            elseif accion:find("ROMPER") or accion:find("BREAK") or accion:find("HIT") or accion:find("GOLPE") then
                                aplicarEspAObjeto(obj, "BARRIL", Color3.fromRGB(160, 82, 45))
                            end
                        end
                    end
                end
            end
        else
            limpiarEsp()
        end
    end
end)

-- BUCLE 4: MOTOR DE NOCLIP
RunService.Stepped:Connect(function()
    if NoclipActivo then
        local character = LocalPlayer.Character
        if character then
            for _, v in ipairs(character:GetDescendants()) do
                if v:IsA("BasePart") and v.CanCollide == true then
                    v.CanCollide = false
                end
            end
        end
    end
end)

